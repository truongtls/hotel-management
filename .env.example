# Sao chép file này thành .env và chỉnh sửa trước khi chạy docker compose up

# Cổng truy cập website trên máy host
WEB_PORT=8081

# Thông tin database
DB_USER=hotel_user
DB_PASSWORD=hotel_pass
DB_NAME=hotel_db

# Khóa bí mật để ký JWT - BẮT BUỘC đổi khi triển khai thật
JWT_SECRET=please_change_this_secret_key

# Tài khoản admin được tạo tự động khi khởi tạo database lần đầu
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
